#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n gxhro
## shellcheck gxhro

# Exit immediately if a command exits with a non-zero status, ie. no need to
# chain the commands using '&&', since 'set -e' is used.
set -e

set -o xtrace
source /etc/profile 2>/dev/null
guix home roll-back "$@"
{ retval="$?"; set +o xtrace; } 2>/dev/null
exit $retval
