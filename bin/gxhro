#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n gxhro
## shellcheck gxhro

# Exit immediately if a command exits with a non-zero status, ie. no need to
# chain the commands using '&&', since 'set -e' is used.
set -o errexit  # set -e
set -o nounset  # set -u
set -o pipefail

set -o xtrace   # set -x
set +o nounset  # set +u
# shellcheck disable=SC1091
source /etc/profile 2>/dev/null
set -o nounset  # set -u

guix home roll-back "$@"
{ retval="$?"; set +o xtrace; } 2>/dev/null
exit $retval
