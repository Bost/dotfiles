#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n run-qemu
## shellcheck run-qemu

# '--preserve-env=GUILE_LOAD_COMPILED_PATH' makes the (dotf utils) scheme module
# accessible to the super-user
set -o xtrace
sudo --preserve-env=GUILE_LOAD_COMPILED_PATH \
     guile \
     -e '(@ (scm-bin qemu-vm) main)' \
     ~/scm-bin/qemu-vm \
     --user=$USER \
     $@
# { retval="$?"; set +o xtrace; } 2>/dev/null
