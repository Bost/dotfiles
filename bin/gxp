#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status, ie. no need to
# chain the commands using '&&', since 'set -e' is used.
set -e

tstp=$(date +%F_%H-%M-%S)
baseLP=$dotf/guix # base-load-path

set -x # Print commands and their arguments as they are executed.
# prevent 'WARNING: ... incompatible bytecode version'
source /etc/profile 2>/dev/null
# --unsafe-channel-evaluation allow:
#   - access to bindings such as system (to run shell code)
#   - use additional modules
#   - etc.
guix pull --unsafe-channel-evaluation --allow-downgrades \
     --load-path=$baseLP/common \
     --channels=$baseLP/home/common/home-channels.scm \
     "$@"

# No need to chain the commands using '&&', since 'set -e' is used.
# guix describe

{ retval="$?"; set +x; } 2>/dev/null

exit $retval
