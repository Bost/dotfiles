#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n rm-link
## shellcheck rm-link

if [ "$#" -lt 1 ]; then
    echo "Usage: $0 <symlink>..." >&2
    exit 1
fi

for symlink in "$@"; do
    if [ ! -L "$symlink" ]; then
        echo "[ERROR] $symlink is not a symlink. Refusing to remove." >&2
        exit 1
    fi
done

rm "$@"
