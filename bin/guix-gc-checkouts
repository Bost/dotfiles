#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n guix-gc-checkouts
## shellcheck guix-gc-checkouts

find $HOME/.cache/guix/checkouts \
    -mindepth 1 \
    -maxdepth 1 \
    -type d \
    -exec test -d {}/.git ';' \
    -exec printf 'git gc: %s\n' {} ';' \
    -exec git -C {} gc ';'
