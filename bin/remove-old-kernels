#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n remove-old-kernels
## shellcheck remove-old-kernels

echo "# Current kernel:" $(uname -a)

# create a list of old kernels
old=$(dpkg -l 'linux-image-*' | sed '/^ii/!d;/'"$(uname -r | sed "s/\(.*\)-\([^0-9]\+\)/\1/")"'/d;s/^[^ ]* [^ ]* \([^ ]*\).*/\1/;/[0-9]/!d')

if [[ -z "$old" ]]; then
    echo "No old kernel found"
else
    echo sudo apt remove --purge $old
fi
