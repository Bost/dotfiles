#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n gxhco
## shellcheck gxhco

set -o errexit  # set -e
set -o nounset  # set -u
set -o pipefail

: "${dtf:?Variable dtf is not set or empty}"
baseLP="$dtf/guix" # base-load-path
configFile=$(printf "%s/home/home-%s.scm" "$baseLP" "$(hostname)")

set -o xtrace   # set -x
set +o nounset  # set +u
# shellcheck disable=SC1091
source /etc/profile 2>/dev/null
set -o nounset  # set -u

guix home --allow-downgrades \
     --load-path="$baseLP/common" \
     --load-path="$baseLP/home/common" \
     container \
     "$configFile" "$@"

{ retval="$?"; set +o xtrace; } 2>/dev/null

exit $retval
