#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash -*-

## bash -n gxhco
## shellcheck gxhco

baseLP=$dotf/guix # base-load-path
hostname=$(hostname)

configFile=$(printf "%s/home/home-%s.scm" $baseLP $hostname)

set -o xtrace
source /etc/profile 2>/dev/null
guix home --allow-downgrades \
     -L $baseLP/common \
     -L $baseLP/home/common \
     container \
     $configFile "$@"
{ retval="$?"; set +o xtrace; } 2>/dev/null
exit $retval
